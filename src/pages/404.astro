---
import PageLayout from '../layouts/PageLayout.astro';

const description =
  "404 Page Not Found - The page you're looking for doesn't exist.";
---

<PageLayout
  title='Not Found'
  description={description}
  class='page-stack error-page'
>
  <h1 class='page-title'>Oops!</h1>
  <h2>Page Not Found.</h2>
  <p>
    It looks like the page you are looking for does not exist or has been
    removed. Go back or head over to the <a href='/'>home page</a> to choose a new
    direction.
  </p>

  <a href='/' class='button-link'>Go Home</a>
</PageLayout>
